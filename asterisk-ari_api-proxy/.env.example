# API Proxy Configuration
ARI_URL=http://127.0.0.1:8088/ari
ARI_USER=whisper
ARI_PASS=your-ari-password-here

# Metadata Log File Path (Host path matched in docker-compose)
META_LOG_FILE=/var/log/asterisk/audiosocket_meta.json

# Directory containing conversation audio files (speaker_1_filtered.wav, speaker_2_filtered.wav)
AUDIO_DIR=/data/dialogues
